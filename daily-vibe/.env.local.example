# Copy this file to .env.local and fill in your values.
# Database: run new SQL in supabase/migrations/ (003_daily_wellness, 004_task_recurrence) via Supabase SQL Editor if upgrading.
# ─────────────────────────────────────────────────────
# Supabase — find in: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────
# Web Push / VAPID Keys
# Generate once with:  npx web-push generate-vapid-keys
#
# IMPORTANT: Back up VAPID_PRIVATE_KEY — it cannot be regenerated.
# If lost, all existing push subscriptions become invalid.
VAPID_SUBJECT=mailto:your-email@example.com
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
# Same as VAPID_PUBLIC_KEY — exposed to the browser for subscription
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ─────────────────────────────────────────────────────
# Cron Secret — protects the /api/push/cron endpoint
# Use any long random string (e.g. openssl rand -hex 32)
CRON_SECRET=your-cron-secret-here

# ─────────────────────────────────────────────────────
# Account export — emails a ZIP of CSVs via Resend (server-only)
# Dashboard: https://resend.com — verify a sending domain, then set:
RESEND_API_KEY=re_xxxxxxxx
# Must be an address on your verified domain, e.g. noreply@mail.yourdomain.com
RESEND_FROM_EMAIL=noreply@your-verified-domain.com

# Supabase Auth — email change / magic links
# Dashboard → Authentication → URL Configuration:
#   Site URL: your app origin (e.g. https://daily-vibe.vercel.app)
#   Redirect URLs: include https://YOUR_ORIGIN/auth/callback
# Email change uses updateUser; users confirm via the link Supabase sends.
